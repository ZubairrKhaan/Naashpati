# Environment Configuration
NODE_ENV=development

# Server
PORT=5000

# Database
MONGODB_URI=mongodb+srv://admin:311Naashpati113@naashpati.leexkrt.mongodb.net/naashpati?retryWrites=true&w=majority&appName=Naashpati

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
